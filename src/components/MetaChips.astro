---
/**
 * MetaChips.astro — small, non-interactive pill chips summarizing a concept's
 * metadata. For concepts: Bucket, Maturity, Effort, and each "Best for" item.
 * For recipes: Build target, Feel, Effort.
 *
 * Effort gets a subtle visual weight (a 1–3 dot meter) but NO rainbow color —
 * only neutral/accent shades, per the design guidelines.
 */
import type { ConceptMeta } from "@/lib/parse-library";

interface Props {
  meta: ConceptMeta;
  isRecipe: boolean;
}

const { meta, isRecipe } = Astro.props;

type Chip = { prefix: string; value: string; kind?: "effort" };

const chips: Chip[] = [];

/** "saas-landing" -> "Saas landing". Recipe build targets are stored as slugs. */
function humanize(slug: string): string {
  const spaced = slug.replace(/-/g, " ").trim();
  return spaced.charAt(0).toUpperCase() + spaced.slice(1);
}

if (isRecipe) {
  if (meta.buildTarget) chips.push({ prefix: "Build", value: humanize(meta.buildTarget) });
  if (meta.feel) chips.push({ prefix: "Feel", value: meta.feel });
  if (meta.effort) chips.push({ prefix: "Effort", value: meta.effort, kind: "effort" });
} else {
  if (meta.bucket) chips.push({ prefix: "Bucket", value: meta.bucket });
  if (meta.maturity) chips.push({ prefix: "Maturity", value: meta.maturity });
  if (meta.effort) chips.push({ prefix: "Effort", value: meta.effort, kind: "effort" });
  for (const item of meta.bestFor ?? []) {
    chips.push({ prefix: "Best for", value: item });
  }
}

---

{
  chips.length > 0 && (
    <ul class="metachips" role="list" aria-label="Concept metadata">
      {chips.map((chip) => (
        <li class="metachip">
          <span class="metachip__prefix">{chip.prefix}</span>
          <span class="metachip__value">{chip.value}</span>
        </li>
      ))}
    </ul>
  )
}

<style>
  .metachips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .metachip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: 0.28em 0.7em;
    border: var(--border-hair) solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    font-size: var(--step--1);
    line-height: 1.3;
    color: var(--text);
  }

  .metachip__prefix {
    font-family: var(--font-mono);
    font-size: 0.82em;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .metachip__value {
    color: var(--text-strong);
    font-weight: 550;
  }
</style>
