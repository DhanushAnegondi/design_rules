---
/**
 * Toc.astro — "On this page" navigation. Anchor links to each section.
 * Sticky on wide screens (the parent aside provides the sticky context too).
 *
 * Progressive enhancement: a tiny inline script marks the section currently in
 * view via IntersectionObserver and sets aria-current on its link. Without JS the
 * links still work (plain anchors). Under prefers-reduced-motion we skip the
 * observer entirely so there is no shifting active-indicator — the list is just a
 * static set of links, which is the calm fallback.
 */
import type { Section } from "@/lib/parse-library";

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

{
  sections.length > 0 && (
    <nav class="toc" aria-label="On this page">
      <p class="toc__title">On this page</p>
      <ol class="toc__list" role="list">
        {sections.map((section) => (
          <li>
            <a class="toc__link" href={`#${section.slug}`} data-toc-link={section.slug}>
              {section.title}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}

<script is:inline>
  (function () {
    // --- Open the enclosing <details> when a TOC link targets a collapsed
    //     section, then scroll the heading into view. Progressive enhancement:
    //     without JS the anchors still navigate; this just makes a collapsed
    //     section reveal itself. Runs regardless of reduced-motion.
    function revealTarget(id) {
      if (!id) return;
      var target = document.getElementById(id);
      if (!target) return;
      // Walk up: open every <details> ancestor so the target is visible.
      var node = target;
      while (node && node !== document.body) {
        if (
          node.tagName &&
          node.tagName.toLowerCase() === "details" &&
          !node.open
        ) {
          node.open = true;
        }
        node = node.parentNode;
      }
      // Defer scroll until after the details have laid out.
      var reduceMq =
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.requestAnimationFrame(function () {
        target.scrollIntoView({
          behavior: reduceMq ? "auto" : "smooth",
          block: "start",
        });
      });
    }

    document.addEventListener("click", function (e) {
      var a = e.target && e.target.closest && e.target.closest("[data-toc-link]");
      if (!a) return;
      var id = a.getAttribute("data-toc-link");
      var target = document.getElementById(id);
      if (!target) return;
      // Only intercept to open a collapsed section; let the browser handle the
      // hash update afterwards.
      e.preventDefault();
      revealTarget(id);
      // Update the URL hash without an extra jump.
      if (history.replaceState) history.replaceState(null, "", "#" + id);
      else window.location.hash = id;
    });

    window.addEventListener("hashchange", function () {
      var id = decodeURIComponent((window.location.hash || "").replace(/^#/, ""));
      revealTarget(id);
    });

    // On initial load with a hash (e.g. shared deep link), reveal it.
    if (window.location.hash) {
      revealTarget(
        decodeURIComponent(window.location.hash.replace(/^#/, ""))
      );
    }
  })();

  (function () {
    var reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return; // calm fallback: no moving active indicator

    var links = Array.prototype.slice.call(
      document.querySelectorAll("[data-toc-link]")
    );
    if (!links.length || !("IntersectionObserver" in window)) return;

    var byId = {};
    links.forEach(function (a) {
      byId[a.getAttribute("data-toc-link")] = a;
    });

    var visible = {};
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          visible[entry.target.id] = entry.isIntersecting;
        });
        // Highlight the first section currently intersecting, in document order.
        var current = null;
        for (var i = 0; i < links.length; i++) {
          var id = links[i].getAttribute("data-toc-link");
          if (visible[id]) {
            current = id;
            break;
          }
        }
        links.forEach(function (a) {
          var on = a.getAttribute("data-toc-link") === current;
          if (on) a.setAttribute("aria-current", "true");
          else a.removeAttribute("aria-current");
        });
      },
      { rootMargin: "0px 0px -70% 0px", threshold: 0 }
    );

    links.forEach(function (a) {
      var el = document.getElementById(a.getAttribute("data-toc-link"));
      if (el) observer.observe(el);
    });
  })();
</script>

<style>
  .toc {
    font-size: var(--step--1);
  }

  .toc__title {
    font-family: var(--font-mono);
    font-size: 0.82em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--faint);
    margin-block-end: var(--space-xs);
  }

  .toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1px;
    /* The accent rail sits to the left; links indent past it. */
    border-inline-start: var(--border-hair) solid var(--border);
  }

  .toc__link {
    display: block;
    padding: 0.4em var(--space-s);
    margin-inline-start: -1px;
    border-inline-start: 2px solid transparent;
    color: var(--muted);
    text-decoration: none;
    line-height: 1.35;
  }

  .toc__link:hover {
    color: var(--text-strong);
  }

  .toc__link[aria-current="true"] {
    color: var(--text-strong);
    border-inline-start-color: var(--accent);
    font-weight: 550;
  }

  .toc__link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
    border-radius: 3px;
  }
</style>
