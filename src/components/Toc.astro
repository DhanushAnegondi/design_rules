---
/**
 * Toc.astro — "On this page" navigation. Anchor links to each section.
 * Sticky on wide screens (the parent aside provides the sticky context too).
 *
 * Progressive enhancement: a tiny inline script marks the section currently in
 * view via IntersectionObserver and sets aria-current on its link. Without JS the
 * links still work (plain anchors). Under prefers-reduced-motion we skip the
 * observer entirely so there is no shifting active-indicator — the list is just a
 * static set of links, which is the calm fallback.
 */
import type { Section } from "@/lib/parse-library";
import { sectionLabel } from "@/lib/section-labels";

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

{
  sections.length > 0 && (
    <nav class="toc" aria-label="On this page">
      <p class="toc__title">On this page</p>
      <ol class="toc__list" role="list">
        {sections.map((section) => {
          const label = sectionLabel(section.title);
          return (
            <li>
              <a
                class="toc__link"
                href={`#${section.slug}`}
                data-toc-link={section.slug}
                aria-label={label.ambiguous ? label.full : undefined}
                title={label.ambiguous ? label.full : undefined}
              >
                <span class="toc__text">{label.short}</span>
              </a>
            </li>
          );
        })}
      </ol>
    </nav>
  )
}

<script is:inline>
  (function () {
    // --- Open the enclosing <details> when a TOC link targets a collapsed
    //     section, then scroll the heading into view. Progressive enhancement:
    //     without JS the anchors still navigate; this just makes a collapsed
    //     section reveal itself. Runs regardless of reduced-motion.
    function revealTarget(id) {
      if (!id) return;
      var target = document.getElementById(id);
      if (!target) return;
      // Walk up: open every <details> ancestor so the target is visible.
      var node = target;
      while (node && node !== document.body) {
        if (
          node.tagName &&
          node.tagName.toLowerCase() === "details" &&
          !node.open
        ) {
          node.open = true;
        }
        node = node.parentNode;
      }
      // Defer scroll until after the details have laid out.
      var reduceMq =
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.requestAnimationFrame(function () {
        target.scrollIntoView({
          behavior: reduceMq ? "auto" : "smooth",
          block: "start",
        });
      });
    }

    document.addEventListener("click", function (e) {
      var a = e.target && e.target.closest && e.target.closest("[data-toc-link]");
      if (!a) return;
      var id = a.getAttribute("data-toc-link");
      var target = document.getElementById(id);
      if (!target) return;
      // Only intercept to open a collapsed section; let the browser handle the
      // hash update afterwards.
      e.preventDefault();
      revealTarget(id);
      // Update the URL hash without an extra jump.
      if (history.replaceState) history.replaceState(null, "", "#" + id);
      else window.location.hash = id;
    });

    window.addEventListener("hashchange", function () {
      var id = decodeURIComponent((window.location.hash || "").replace(/^#/, ""));
      revealTarget(id);
    });

    // On initial load with a hash (e.g. shared deep link), reveal it — after the
    // DOM is parsed, since this aside renders before the <article>.
    function revealInitialHash() {
      if (window.location.hash) {
        revealTarget(
          decodeURIComponent(window.location.hash.replace(/^#/, ""))
        );
      }
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", revealInitialHash);
    } else {
      revealInitialHash();
    }
  })();

  (function () {
    // Scroll-spy runs in ALL motion modes: the active section gets highlighted
    // and bold. The DIFFERENCE under prefers-reduced-motion is purely CSS — the
    // magnify scale + transitions are disabled there (see the stylesheet), so we
    // keep a calm, non-animated bold+accent state rather than no indicator.
    //
    // IMPORTANT: this aside (the TOC + this script) renders BEFORE the <article>
    // in source order, so at parse time the section headings do not exist yet and
    // getElementById() would return null. Defer setup until the DOM is parsed.
    function initSpy() {
    var links = Array.prototype.slice.call(
      document.querySelectorAll("[data-toc-link]")
    );
    if (!links.length || !("IntersectionObserver" in window)) return;

    var byId = {};
    links.forEach(function (a) {
      byId[a.getAttribute("data-toc-link")] = a;
    });

    var visible = {};
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          visible[entry.target.id] = entry.isIntersecting;
        });
        // Highlight the first section currently intersecting, in document order.
        var current = null;
        for (var i = 0; i < links.length; i++) {
          var id = links[i].getAttribute("data-toc-link");
          if (visible[id]) {
            current = id;
            break;
          }
        }
        links.forEach(function (a) {
          var on = a.getAttribute("data-toc-link") === current;
          if (on) a.setAttribute("aria-current", "true");
          else a.removeAttribute("aria-current");
        });
      },
      { rootMargin: "0px 0px -70% 0px", threshold: 0 }
    );

    links.forEach(function (a) {
      var el = document.getElementById(a.getAttribute("data-toc-link"));
      if (el) observer.observe(el);
    });
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initSpy);
    } else {
      initSpy();
    }
  })();
</script>

<style>
  .toc {
    font-size: var(--step--1);
  }

  .toc__title {
    font-family: var(--font-mono);
    font-size: 0.82em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--faint);
    margin-block-end: var(--space-s);
  }

  .toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
    /* The accent rail sits to the left; links indent past it. */
    border-inline-start: var(--border-hair) solid var(--border);
  }

  .toc__link {
    /* Flex with a reserved row height so the active line can magnify without
       pushing the list taller (transform is visual-only; the steady min-height
       keeps the rhythm calm). */
    display: flex;
    align-items: center;
    min-block-size: 1.9em;
    padding: 0.3em var(--space-s);
    margin-inline-start: -1px;
    border-inline-start: 2px solid transparent;
    color: var(--muted);
    text-decoration: none;
    line-height: 1.35;
    /* Only color/border animate by default; the magnify lives on the inner span
       (transform) so it never nudges the rail or the list height. */
    transition:
      color var(--dur-mid) var(--ease-out-quart),
      border-color var(--dur-mid) var(--ease-out-quart);
  }

  /* The label text is the element we scale, with a left transform-origin so the
     active entry grows toward the reader from the rail, not from its centre —
     no horizontal drift, no layout shift (transform doesn't reflow siblings). */
  .toc__text {
    display: inline-block;
    transform-origin: left center;
    transition:
      transform var(--dur-mid) var(--ease-out-quart),
      font-weight var(--dur-mid) var(--ease-out-quart);
    will-change: transform;
  }

  .toc__link:hover {
    color: var(--text-strong);
  }

  /* Scroll-spy: the section currently in view is HIGHLIGHTED, BOLD, and
     MAGNIFIED; the others recede (quieter colour, normal weight, base scale).
     We reserve vertical room for the larger active line via min-block-size on
     every row so the grow never pushes the list taller. */
  .toc__link[aria-current="true"] {
    color: var(--text-strong);
    border-inline-start-color: var(--accent);
    font-weight: 650;
  }

  .toc__link[aria-current="true"] .toc__text {
    transform: scale(1.14);
    font-weight: 650;
  }

  /* When ANY entry is active, push the rest quieter so the active one reads as
     the clear focus rather than merely "also bold". */
  .toc__list:has([aria-current="true"]) .toc__link:not([aria-current="true"]) {
    color: var(--faint);
  }

  .toc__link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
    border-radius: 3px;
  }

  /* Reduced motion: keep the emphasis (bold + accent rail + recede), drop the
     scale and all transitions. No magnify jitter, just a calm static state. */
  @media (prefers-reduced-motion: reduce) {
    .toc__link,
    .toc__text {
      transition: none;
    }
    .toc__link[aria-current="true"] .toc__text {
      transform: none;
    }
  }
</style>
