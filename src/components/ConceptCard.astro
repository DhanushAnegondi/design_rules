---
/**
 * ConceptCard.astro — a compact card linking to a single concept
 * (`/{concept.domainId}/{concept.slug}`).
 *
 * Shows the title, the one-line definition, and a compact metadata row. A full
 * <MetaChips> row (with every "Best for" item) is too heavy for a card, so this
 * uses a trimmed inline version: the two most identifying facts for the kind of
 * entry (Bucket + Maturity for concepts, Build + Feel for recipes). The concept
 * page renders the full chips. This component is self-contained so it can be
 * reused by the domain landing page.
 */
import type { Concept } from "@/lib/parse-library";

interface Props {
  concept: Concept;
}

const { concept } = Astro.props;

const href = `/${concept.domainId}/${concept.slug}`;

// Compact, identifying facts only — not the full chip set.
const facts: string[] = [];
if (concept.isRecipe) {
  if (concept.meta.buildTarget) {
    facts.push(
      concept.meta.buildTarget
        .replace(/-/g, " ")
        .replace(/^./, (c) => c.toUpperCase())
    );
  }
  if (concept.meta.feel) facts.push(concept.meta.feel);
} else {
  if (concept.meta.bucket) facts.push(concept.meta.bucket);
  if (concept.meta.maturity) facts.push(concept.meta.maturity);
}
// Keep it to two so the row never wraps to three lines on a narrow card.
const compactFacts = facts.slice(0, 2);
---

<a class="concept-card" href={href}>
  <span class="concept-card__head">
    <span class="concept-card__title">{concept.title}</span>
  </span>

  {
    concept.definition && (
      <span class="concept-card__def">{concept.definition}</span>
    )
  }

  {
    compactFacts.length > 0 && (
      <span class="concept-card__facts" aria-hidden="false">
        {compactFacts.map((f, i) => (
          <>
            {i > 0 && <span class="concept-card__sep" aria-hidden="true">·</span>}
            <span class="concept-card__fact">{f}</span>
          </>
        ))}
      </span>
    )
  }
</a>

<style>
  .concept-card {
    /* Shares the DomainCard rhythm: title + definition are one unit at the top,
       the facts row is pinned to the floor (margin-block-end:auto on the def
       block via the layout below), so a grid of these reads as one tidy system.
       Generous, even internal padding — nothing crammed against an edge. */
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    min-block-size: 44px;
    block-size: 100%;
    padding: var(--space-l);
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-m);
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition:
      transform var(--dur-mid) var(--ease-out-expo),
      border-color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .concept-card:hover {
    background: var(--surface-2);
    border-color: var(--border-strong);
    transform: translateY(-3px);
  }

  .concept-card:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 3px;
  }

  .concept-card__head {
    display: flex;
    align-items: baseline;
  }

  .concept-card__title {
    font-family: var(--font-display);
    /* Confident display cut; tracking eased above the floor so glyphs breathe. */
    font-weight: 580;
    font-size: var(--step-1);
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--text-strong);
    font-variation-settings: "opsz" 40;
    text-wrap: balance;
  }

  /* Title + definition form one block; the facts row gets pushed to the floor so
     a row of cards aligns its meta on a shared baseline regardless of def length. */
  .concept-card__def {
    margin-block-end: auto;
    color: var(--muted);
    font-size: var(--step--1);
    line-height: 1.55;
    max-inline-size: 42ch;
    text-wrap: pretty;
    /* Keep cards even: clamp to two lines. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* The facts row is quiet meta: mono, faint, open tracking. No extra top margin
     (the flex gap + the def's auto margin handle separation) so it never
     double-spaces against the definition. */
  .concept-card__facts {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--faint);
  }

  .concept-card__sep {
    color: var(--border-strong);
  }

  @media (prefers-reduced-motion: reduce) {
    .concept-card {
      transition: none;
    }
    .concept-card:hover {
      transform: none;
    }
  }
</style>
