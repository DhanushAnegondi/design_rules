---
/**
 * ColorSwatches.astro — "Colors" disclosure. Collapsed by default into a
 * "Colors (N)" trigger; opening it reveals the swatch list. Each swatch is a
 * real <button> that copies its raw color value to the clipboard via a tiny
 * inline script and shows a transient "Copied" state. An aria-live region
 * announces the copy politely.
 *
 * The disclosure is a native <details>/<summary>: keyboard-operable, present
 * and usable WITHOUT JavaScript (it opens and shows the swatch values; only the
 * one-click copy needs JS, and the raw value is selectable text regardless).
 *
 * The swatch box background comes from data (the color's own css value) — that
 * is the one place raw color is allowed. A swatch close to the page background
 * still gets a visible ring/border so it remains distinguishable.
 *
 * If `colors` is empty the component renders nothing.
 */
import type { ColorValue } from "@/lib/parse-library";

interface Props {
  colors: ColorValue[];
}

const { colors } = Astro.props;
const count = colors.length;
---

{
  count > 0 && (
    <details class="swatches">
      <summary class="swatches__summary">
        <span class="swatches__chevron" aria-hidden="true" />
        <span class="swatches__summary-label">Colors</span>
        <span class="swatches__count" aria-hidden="true">
          {count}
        </span>
        <span class="visually-hidden">
          {count} color {count === 1 ? "value" : "values"} used in this concept
        </span>
      </summary>

      <div class="swatches__body">
        <ul class="swatches__list" role="list">
          {colors.map((color) => (
            <li>
              <button
                type="button"
                class="swatch"
                data-copy={color.raw}
                aria-label={`Copy ${color.raw}`}
              >
                <span
                  class="swatch__chip"
                  style={`background:${color.css}`}
                  aria-hidden="true"
                />
                <span class="swatch__value">{color.raw}</span>
                <span class="swatch__state" aria-hidden="true" data-state>
                  Copy
                </span>
              </button>
            </li>
          ))}
        </ul>
        <p
          class="visually-hidden"
          role="status"
          aria-live="polite"
          data-swatch-live
        />
      </div>
    </details>
  )
}

<script is:inline>
  (function () {
    var live = document.querySelector("[data-swatch-live]");
    var buttons = document.querySelectorAll(".swatch[data-copy]");
    if (!buttons.length) return;

    buttons.forEach(function (btn) {
      var stateEl = btn.querySelector("[data-state]");
      var timer = null;
      btn.addEventListener("click", function () {
        var value = btn.getAttribute("data-copy") || "";
        function done() {
          if (stateEl) stateEl.textContent = "Copied";
          if (live) live.textContent = "Copied " + value;
          if (timer) window.clearTimeout(timer);
          timer = window.setTimeout(function () {
            if (stateEl) stateEl.textContent = "Copy";
          }, 1500);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(value).then(done, function () {});
        }
      });
    });
  })();
</script>

<style>
  /* ---- Disclosure shell ---------------------------------------------------
     A calm "Colors (N)" trigger that mirrors the TOC's quiet chrome. Collapsed
     by default; native <details> so it is keyboard-operable and works with no
     JS. The trigger sits in the aside under the TOC. */
  .swatches {
    font-size: var(--step--1);
  }

  .swatches__summary {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    min-block-size: 44px;
    padding-inline: var(--space-xs);
    margin-inline: calc(-1 * var(--space-xs));
    border-radius: var(--radius-s);
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--text);
    transition: background-color var(--dur-fast) var(--ease-out-quart);
  }

  .swatches__summary::-webkit-details-marker {
    display: none;
  }
  .swatches__summary::marker {
    content: "";
  }

  .swatches__summary:hover {
    background: var(--surface);
  }

  .swatches__summary:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  /* CSS-drawn chevron: rotates to point down when open. */
  .swatches__chevron {
    flex: none;
    inline-size: 8px;
    block-size: 8px;
    border-inline-end: 2px solid var(--faint);
    border-block-end: 2px solid var(--faint);
    transform: rotate(-45deg);
    transition: transform var(--dur-fast) var(--ease-out-quart);
  }

  .swatches[open] .swatches__chevron {
    transform: rotate(45deg);
  }

  .swatches__summary:hover .swatches__chevron {
    border-color: var(--accent);
  }

  .swatches__summary-label {
    font-family: var(--font-mono);
    font-size: 0.82em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* The count pill: a quiet badge, not a loud number. */
  .swatches__count {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: 1.5em;
    padding-inline: 0.4em;
    border: var(--border-hair) solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.78em;
    line-height: 1.6;
    color: var(--faint);
  }

  .swatches__summary:hover .swatches__count {
    border-color: var(--border-strong);
    color: var(--muted);
  }

  .swatches__body {
    margin-block-start: var(--space-s);
  }

  /* ---- Swatch list --------------------------------------------------------- */
  .swatches__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2xs);
  }

  .swatch {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    inline-size: 100%;
    min-block-size: 36px;
    padding: var(--space-2xs) var(--space-xs);
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-s);
    background: var(--surface);
    color: var(--text);
    text-align: start;
    transition: border-color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .swatch:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  .swatch:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .swatch__chip {
    flex: none;
    inline-size: 1.4rem;
    block-size: 1.4rem;
    border-radius: 6px;
    /* Inner ring keeps near-bg colors distinguishable from the row surface. */
    box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--text) 22%, transparent);
  }

  .swatch__value {
    flex: 1 1 auto;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text-strong);
    overflow-wrap: anywhere;
  }

  .swatch__state {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--faint);
  }

  @media (prefers-reduced-motion: reduce) {
    .swatch,
    .swatches__summary,
    .swatches__chevron {
      transition: none;
    }
  }
</style>
