---
/**
 * ColorSwatches.astro — "Colors used" panel. Each swatch is a real <button> that
 * copies its raw color value to the clipboard via a tiny inline script and shows a
 * transient "Copied" state. An aria-live region announces the copy politely.
 *
 * The swatch box background comes from data (the color's own css value) — that is
 * the one place raw color is allowed. A swatch close to the page background still
 * gets a visible ring/border so it remains distinguishable.
 *
 * If `colors` is empty the component renders nothing.
 */
import type { ColorValue } from "@/lib/parse-library";

interface Props {
  colors: ColorValue[];
}

const { colors } = Astro.props;
---

{
  colors.length > 0 && (
    <section class="swatches" aria-label="Colors used">
      <p class="swatches__title">Colors used</p>
      <ul class="swatches__list" role="list">
        {colors.map((color) => (
          <li>
            <button
              type="button"
              class="swatch"
              data-copy={color.raw}
              aria-label={`Copy ${color.raw}`}
            >
              <span
                class="swatch__chip"
                style={`background:${color.css}`}
                aria-hidden="true"
              />
              <span class="swatch__value">{color.raw}</span>
              <span class="swatch__state" aria-hidden="true" data-state>
                Copy
              </span>
            </button>
          </li>
        ))}
      </ul>
      <p class="visually-hidden" role="status" aria-live="polite" data-swatch-live />
    </section>
  )
}

<script is:inline>
  (function () {
    var live = document.querySelector("[data-swatch-live]");
    var buttons = document.querySelectorAll(".swatch[data-copy]");
    if (!buttons.length) return;

    buttons.forEach(function (btn) {
      var stateEl = btn.querySelector("[data-state]");
      var timer = null;
      btn.addEventListener("click", function () {
        var value = btn.getAttribute("data-copy") || "";
        function done() {
          if (stateEl) stateEl.textContent = "Copied";
          if (live) live.textContent = "Copied " + value;
          if (timer) window.clearTimeout(timer);
          timer = window.setTimeout(function () {
            if (stateEl) stateEl.textContent = "Copy";
          }, 1500);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(value).then(done, function () {});
        }
      });
    });
  })();
</script>

<style>
  .swatches__title {
    font-family: var(--font-mono);
    font-size: 0.82em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--faint);
    margin-block-end: var(--space-xs);
  }

  .swatches__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2xs);
  }

  .swatch {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    inline-size: 100%;
    min-block-size: 36px;
    padding: var(--space-2xs) var(--space-xs);
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-s);
    background: var(--surface);
    color: var(--text);
    text-align: start;
    transition: border-color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .swatch:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  .swatch:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .swatch__chip {
    flex: none;
    inline-size: 1.4rem;
    block-size: 1.4rem;
    border-radius: 6px;
    /* Inner ring keeps near-bg colors distinguishable from the row surface. */
    box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--text) 22%, transparent);
  }

  .swatch__value {
    flex: 1 1 auto;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text-strong);
    overflow-wrap: anywhere;
  }

  .swatch__state {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--faint);
  }

  @media (prefers-reduced-motion: reduce) {
    .swatch {
      transition: none;
    }
  }
</style>
