---
/**
 * ReferenceList.astro — "Related in this library" list of internal cross-reference
 * links to other concepts. Refs are deduped upstream. Each row shows the target
 * concept label and, subtly, which domain it lives in.
 */
import type { CrossRef } from "@/lib/parse-library";
import { domainById } from "@/lib/domains";

interface Props {
  refs: CrossRef[];
}

const { refs } = Astro.props;

const dot = (hue: number) => `oklch(70% 0.13 ${hue})`;
---

{
  refs.length > 0 && (
    <nav class="reflist" aria-label="Related in this library">
      <h2 class="reflist__title">Related in this library</h2>
      <ul class="reflist__list" role="list">
        {refs.map((ref) => {
          const domain = domainById(ref.domainId);
          return (
            <li>
              <a class="reflist__link" href={ref.href}>
                <span class="reflist__label">{ref.label}</span>
                {domain && (
                  <span class="reflist__domain">
                    <span
                      class="reflist__dot"
                      style={`background:${dot(domain.accentHue)}`}
                      aria-hidden="true"
                    />
                    {domain.title}
                  </span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  )
}

<style>
  .reflist__title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    margin-block-end: var(--space-m);
  }

  .reflist__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2xs);
  }

  .reflist__link {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-xs);
    padding: var(--space-s) var(--space-m);
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-m);
    background: var(--surface);
    color: var(--text-strong);
    text-decoration: none;
    transition: border-color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .reflist__link:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
    color: var(--text-strong);
  }

  .reflist__link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .reflist__label {
    font-weight: 550;
  }

  .reflist__domain {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-size: var(--step--1);
    color: var(--muted);
  }

  .reflist__dot {
    inline-size: 0.5rem;
    block-size: 0.5rem;
    border-radius: 50%;
  }

  @media (prefers-reduced-motion: reduce) {
    .reflist__link {
      transition: none;
    }
  }
</style>
