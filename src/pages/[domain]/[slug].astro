---
/**
 * [domain]/[slug].astro — the concept detail page.
 *
 * The most-visited, taste-critical page. For one concept it shows: a header
 * (breadcrumb, title, lead definition, metadata chips), a sticky table of
 * contents + colors aside on wide screens, the full rendered body with live
 * sandboxed previews beside copy-paste code, related cross-references, and
 * prev/next navigation within the same domain.
 */
import Base from "@/layouts/Base.astro";
import MetaChips from "@/components/MetaChips.astro";
import Toc from "@/components/Toc.astro";
import ColorSwatches from "@/components/ColorSwatches.astro";
import ReferenceList from "@/components/ReferenceList.astro";
import CodeBlock from "@/components/CodeBlock.tsx";
import LivePreview from "@/components/LivePreview.tsx";
import Disclosure from "@/components/Disclosure.astro";
import {
  getAllConcepts,
  type Concept,
  type Section,
  type Token,
} from "@/lib/parse-library";
import { domainById } from "@/lib/domains";

export async function getStaticPaths() {
  const concepts = await getAllConcepts();
  return concepts.map((c) => ({
    params: { domain: c.domainId, slug: c.slug },
    props: { concept: c },
  }));
}

interface Props {
  concept: Concept;
}

const { concept } = Astro.props;
const domain = domainById(concept.domainId);

// Prev/next within the SAME domain, in the library's sorted order.
const all = await getAllConcepts();
const siblings = all.filter((c) => c.domainId === concept.domainId);
const idx = siblings.findIndex((c) => c.slug === concept.slug);
const prev = idx > 0 ? siblings[idx - 1] : undefined;
const next = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : undefined;

const hasColors = concept.colors.length > 0;
const hasToc = concept.sections.length > 0;
const hasAside = hasColors || hasToc;

// ---------------------------------------------------------------------------
// Progressive disclosure: classify sections PRIMARY (open) vs SECONDARY
// (collapsed). PRIMARY = overview & decision content (what it is / when to use /
// when not to use / how it works) PLUS whichever section holds the FIRST
// runnable live preview. SECONDARY = everything else (full code listings,
// accessibility deep-dive, references, slop warnings, long-tail sections).
//
// Robustness: if the heuristic yields < 2 primary sections, fall back to
// "first 2 sections open, rest collapsed". The section that holds the first
// live preview is NEVER collapsed.
// ---------------------------------------------------------------------------

function hasRunnable(section: Section): boolean {
  return section.tokens.some((t) => t.type === "code" && t.runnable);
}

/** Index of the first section (document order) that contains a runnable demo. */
const firstPreviewIdx = concept.sections.findIndex(hasRunnable);

const PRIMARY_TITLE_RE =
  /^(what it is|what it'?s|when to use|when not to use|when to use it|when not to use it|how it works)\b/i;

function isPrimaryByTitle(title: string): boolean {
  return PRIMARY_TITLE_RE.test(title.trim());
}

interface SectionPlan {
  section: Section;
  index: number;
  primary: boolean;
}

let plan: SectionPlan[] = concept.sections.map((section, index) => ({
  section,
  index,
  // Never collapse the section that holds the first live preview.
  primary: isPrimaryByTitle(section.title) || index === firstPreviewIdx,
}));

// Fallback: if fewer than 2 primary sections, open the first two outright
// (still never collapsing the first-preview section).
const primaryCount = plan.filter((p) => p.primary).length;
if (primaryCount < 2) {
  plan = plan.map((p) => ({
    ...p,
    primary: p.primary || p.index < 2,
  }));
}

// ---------------------------------------------------------------------------
// Within a PRIMARY section, keep the FIRST runnable preview prominent and tuck
// any ADDITIONAL previews / large code blocks into a nested disclosure so the
// first screen stays light. We split a primary section's tokens into a "lead"
// run (everything up to and including the first runnable preview, plus any
// immediately-following prose) and an "extra" run (subsequent previews and
// large code blocks). Only split when the extra run actually carries weight.
// ---------------------------------------------------------------------------

const LARGE_CODE_LINES = 14; // a code block past this many lines counts as "large"

function isLargeCode(token: Token): boolean {
  return (
    token.type === "code" &&
    !token.runnable &&
    token.code.split("\n").length > LARGE_CODE_LINES
  );
}

interface SplitTokens {
  lead: Token[];
  extra: Token[];
  /** label for the nested disclosure, depends on what's tucked away */
  extraLabel: string;
}

function splitPrimaryTokens(section: Section): SplitTokens {
  const tokens = section.tokens;
  const firstRunnable = tokens.findIndex(
    (t) => t.type === "code" && t.runnable
  );

  // No runnable in this primary section: only tuck away large code if there are
  // several, otherwise keep everything in the lead (it's overview prose).
  if (firstRunnable === -1) {
    const largeIdx = tokens.findIndex(isLargeCode);
    // If there's a single large code block in an overview section, leave it.
    const largeCount = tokens.filter(isLargeCode).length;
    if (largeCount >= 2 && largeIdx !== -1) {
      return {
        lead: tokens.slice(0, largeIdx),
        extra: tokens.slice(largeIdx),
        extraLabel: "Show full code",
      };
    }
    return { lead: tokens, extra: [], extraLabel: "" };
  }

  // Keep through the first runnable preview AND any single prose token right
  // after it (a short caption reads well inline).
  let leadEnd = firstRunnable + 1;
  if (tokens[leadEnd]?.type === "prose") leadEnd += 1;

  const extra = tokens.slice(leadEnd);
  // Only tuck away if the extra run has another preview or a large code block.
  const extraHasWeight = extra.some(
    (t) => (t.type === "code" && t.runnable) || isLargeCode(t)
  );
  if (!extraHasWeight) {
    return { lead: tokens, extra: [], extraLabel: "" };
  }

  const extraHasPreview = extra.some((t) => t.type === "code" && t.runnable);
  return {
    lead: tokens.slice(0, leadEnd),
    extra,
    extraLabel: extraHasPreview ? "Show more examples" : "Show full code",
  };
}
---

<Base title={concept.title} description={concept.definition}>
  <div class="container concept">
    {/* ---- Header ---- */}
    <header class="concept__header">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol role="list">
          <li><a href="/">Home</a></li>
          {
            domain && (
              <li>
                <a href={`/${domain.id}`}>{domain.title}</a>
              </li>
            )
          }
          <li aria-current="page">{concept.title}</li>
        </ol>
      </nav>

      <h1 class="concept__title">{concept.title}</h1>

      {
        concept.definition && (
          <p class="concept__lead">{concept.definition}</p>
        )
      }

      <MetaChips meta={concept.meta} isRecipe={concept.isRecipe} />
    </header>

    {/* ---- Body: aside + article ---- */}
    <div class="concept__grid" data-has-aside={hasAside ? "true" : "false"}>
      {
        hasAside && (
          <aside class="concept__aside">
            <div class="concept__aside-inner">
              {hasToc && <Toc sections={concept.sections} />}
              {hasColors && <ColorSwatches colors={concept.colors} />}
            </div>
          </aside>
        )
      }

      <article class="concept__article">
        {
          plan.map(({ section, primary }) => {
            // Token renderer shared by primary lead/extra and secondary bodies.
            const renderToken = (token: Token) =>
              token.type === "prose" ? (
                <div class="prose" set:html={token.html} />
              ) : token.runnable ? (
                <div class="concept__demo">
                  <LivePreview
                    code={token.code}
                    highlighted={token.highlighted}
                    lang={token.lang}
                    client:visible
                  />
                </div>
              ) : (
                <div class="concept__code">
                  <CodeBlock
                    code={token.code}
                    highlighted={token.highlighted}
                    lang={token.lang}
                    client:visible
                  />
                </div>
              );

            if (!primary) {
              // SECONDARY: collapsed by default. The heading id lives on the
              // <details> so TOC links can find and open it. The visible <h2>
              // sits inside the summary's row context but we keep a real
              // heading inside the body for document structure.
              return (
                <section class="concept__section concept__section--secondary">
                  <Disclosure
                    summaryLabel={`Show: ${section.title}`}
                    id={section.slug}
                    variant="section"
                  >
                    <h2 class="concept__h2 concept__h2--insummary">
                      {section.title}
                    </h2>
                    {section.tokens.map(renderToken)}
                  </Disclosure>
                </section>
              );
            }

            // PRIMARY: open. Split off extra previews/large code into a nested
            // disclosure to keep the first screen light.
            const { lead, extra, extraLabel } = splitPrimaryTokens(section);
            return (
              <section class="concept__section">
                <h2 id={section.slug} class="concept__h2">
                  {section.title}
                </h2>
                {lead.map(renderToken)}
                {extra.length > 0 && (
                  <Disclosure summaryLabel={extraLabel} variant="inline">
                    {extra.map(renderToken)}
                  </Disclosure>
                )}
              </section>
            );
          })
        }

        {
          concept.crossRefs.length > 0 && (
            <div class="concept__related">
              <ReferenceList refs={concept.crossRefs} />
            </div>
          )
        }

        {/* ---- Prev / next within this domain ---- */}
        {
          (prev || next) && (
            <nav class="concept__pager" aria-label="More in this domain">
              {prev ? (
                <a
                  class="pager pager--prev"
                  rel="prev"
                  href={`/${prev.domainId}/${prev.slug}`}
                >
                  <span class="pager__dir">Previous</span>
                  <span class="pager__title">{prev.title}</span>
                </a>
              ) : (
                <span />
              )}
              {next ? (
                <a
                  class="pager pager--next"
                  rel="next"
                  href={`/${next.domainId}/${next.slug}`}
                >
                  <span class="pager__dir">Next</span>
                  <span class="pager__title">{next.title}</span>
                </a>
              ) : (
                <span />
              )}
            </nav>
          )
        }
      </article>
    </div>
  </div>
</Base>

<style>
  .concept {
    padding-block: var(--space-xl) var(--space-3xl);
  }

  /* ---- Header ---- */
  .concept__header {
    max-inline-size: var(--measure);
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2xs) var(--space-xs);
    list-style: none;
    margin: 0 0 var(--space-m);
    padding: 0;
    font-size: var(--step--1);
    color: var(--muted);
  }

  .breadcrumb li {
    display: inline-flex;
    align-items: center;
  }

  .breadcrumb li + li::before {
    content: "/";
    margin-inline-end: var(--space-xs);
    color: var(--faint);
  }

  .breadcrumb a {
    color: var(--muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--text);
  }

  .concept__title {
    margin-block: var(--space-xs) var(--space-m);
  }

  .concept__lead {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--muted);
    margin-block-end: var(--space-l);
  }

  /* ---- Grid: aside + article ---- */
  .concept__grid {
    margin-block-start: var(--space-2xl);
    display: grid;
    gap: var(--space-xl);
  }

  @media (min-width: 60rem) {
    .concept__grid[data-has-aside="true"] {
      grid-template-columns: minmax(0, 1fr) 16rem;
    }

    /* Aside goes to the right column visually; article first in source for a11y. */
    .concept__grid[data-has-aside="true"] .concept__aside {
      grid-column: 2;
      grid-row: 1;
    }

    .concept__grid[data-has-aside="true"] .concept__article {
      grid-column: 1;
      grid-row: 1;
    }
  }

  .concept__aside-inner {
    display: grid;
    gap: var(--space-xl);
  }

  @media (min-width: 60rem) {
    .concept__aside-inner {
      position: sticky;
      inset-block-start: calc(60px + var(--space-m));
      max-block-size: calc(100vh - 60px - var(--space-xl));
      overflow-y: auto;
      padding-block-end: var(--space-m);
    }
  }

  /* ---- Article ---- */
  .concept__article {
    min-inline-size: 0;
  }

  /* Calm rhythm: generous breathing room between bands; lean on whitespace
     rather than borders to separate one idea from the next. */
  .concept__section + .concept__section {
    margin-block-start: var(--space-3xl);
  }

  /* Secondary (collapsed) sections sit closer together — a quiet stack of
     disclosure rows, not full bands. */
  .concept__section--secondary + .concept__section--secondary {
    margin-block-start: var(--space-m);
  }

  .concept__h2 {
    font-size: var(--step-2);
    scroll-margin-block-start: calc(60px + var(--space-l));
    margin-block-end: var(--space-m);
    /* Quieter rule: no heavy underline on every heading. Whitespace separates. */
  }

  /* Heading shown inside an expanded secondary disclosure: it already follows a
     "Show: …" summary row, so keep it understated. */
  .concept__h2--insummary {
    font-size: var(--step-1);
    margin-block-start: 0;
    margin-block-end: var(--space-s);
    color: var(--text-strong);
  }

  /* Prose sits within a comfortable reading measure. */
  .concept__section :global(.prose) {
    margin-block-start: var(--space-m);
    max-inline-size: var(--measure);
  }

  /* Code samples align with the prose measure but allow horizontal scroll. */
  .concept__code {
    margin-block-start: var(--space-m);
    max-inline-size: var(--measure);
  }

  /* Live demos break out wider than the prose measure so the effect has room. */
  .concept__demo {
    margin-block-start: var(--space-l);
  }

  @media (min-width: 75rem) {
    .concept__demo {
      /* Gentle break-out past the reading measure on very wide screens. */
      margin-inline-end: calc(-1 * var(--space-2xl));
    }
  }

  .concept__related {
    margin-block-start: var(--space-3xl);
  }

  /* ---- Pager ---- */
  .concept__pager {
    margin-block-start: var(--space-2xl);
    padding-block-start: var(--space-xl);
    border-block-start: var(--border-hair) solid var(--border);
    display: grid;
    gap: var(--space-m);
    grid-template-columns: 1fr 1fr;
  }

  .pager {
    display: grid;
    gap: var(--space-2xs);
    padding: var(--space-m);
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-m);
    background: var(--surface);
    text-decoration: none;
    color: var(--text-strong);
    transition: border-color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .pager--next {
    text-align: end;
  }

  .pager:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
    color: var(--text-strong);
  }

  .pager:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .pager__dir {
    font-family: var(--font-mono);
    font-size: 0.8em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .pager__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.2;
  }

  @media (prefers-reduced-motion: reduce) {
    .pager {
      transition: none;
    }
  }

  /* ---- Live preview + code block component styles (global; islands render markup) ---- */
  :global(.livepreview) {
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-l);
    overflow: hidden;
    background: var(--bg-elev);
  }

  :global(.livepreview__bar) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-m);
    border-block-end: var(--border-hair) solid var(--border);
    background: var(--surface);
  }

  :global(.livepreview__label) {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  :global(.livepreview__controls) {
    display: flex;
    gap: var(--space-2xs);
  }

  :global(.livepreview__btn) {
    min-block-size: 36px;
    padding-inline: var(--space-s);
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-s);
    background: var(--bg-elev);
    color: var(--text);
    font-size: var(--step--1);
    transition: border-color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  :global(.livepreview__btn:hover) {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  :global(.livepreview__btn:focus-visible) {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  /* Classifier-driven hint row (scroll / pointer / loop). Calm, low-contrast. */
  :global(.livepreview__hint) {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin: 0;
    padding: var(--space-xs) var(--space-m);
    border-block-end: var(--border-hair) solid var(--border);
    background: color-mix(in oklch, var(--accent) 7%, var(--surface));
    color: var(--muted);
    font-size: var(--step--1);
  }

  /* CSS-drawn downward arrow for the scroll hint (no emoji). A chevron: a
     square with two borders rotated 45deg so it points down. */
  :global(.livepreview__hint-arrow) {
    flex: none;
    inline-size: 8px;
    block-size: 8px;
    border-inline-end: 2px solid var(--accent);
    border-block-end: 2px solid var(--accent);
    transform: rotate(45deg);
  }

  :global(.livepreview__frame-wrap) {
    background: var(--preview-bg);
    /* Never clip the iframe's own scrolling. */
    overflow: visible;
  }

  :global(.livepreview__frame) {
    display: block;
    inline-size: 100%;
    block-size: 380px;
    border: 0;
  }

  /* Scroll demos need real travel: the iframe is the scroll root for
     animation-timeline: scroll(root block), so give it a taller default frame
     and let it scroll internally. */
  :global(.livepreview[data-kind="scroll"] .livepreview__frame) {
    block-size: 560px;
  }

  :global(.livepreview__frame-wrap[data-expanded="true"] .livepreview__frame) {
    block-size: 680px;
  }

  :global(
      .livepreview[data-kind="scroll"]
        .livepreview__frame-wrap[data-expanded="true"]
        .livepreview__frame
    ) {
    block-size: 760px;
  }

  /* ---- CodeBlock ---- */
  :global(.codeblock) {
    margin: 0;
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-m);
    overflow: hidden;
    background: var(--bg-elev);
  }

  /* When the code block is embedded inside a live preview, square the top edge
     so it reads as one card with the iframe above it. */
  :global(.livepreview .codeblock--inpreview) {
    border-inline: 0;
    border-block-end: 0;
    border-radius: 0;
    border-block-start: var(--border-hair) solid var(--border);
  }

  :global(.codeblock__bar) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
    padding: var(--space-2xs) var(--space-m);
    border-block-end: var(--border-hair) solid var(--border);
    background: var(--surface);
  }

  :global(.codeblock__lang) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    color: var(--muted);
  }

  :global(.codeblock__copy) {
    min-block-size: 32px;
    padding-inline: var(--space-s);
    border: var(--border-hair) solid var(--border);
    border-radius: var(--radius-s);
    background: var(--bg-elev);
    color: var(--text);
    font-size: var(--step--1);
    transition: border-color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  :global(.codeblock__copy:hover) {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }

  :global(.codeblock__copy:focus-visible) {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  :global(.codeblock__code) {
    /* Long code lines scroll horizontally within the card.
       overflow-x: auto contains the scroll so no document-level overflow leaks.
       min-inline-size: 0 prevents the flex/grid child from overflowing its track.
       overflow-y stays visible (default) so no vertical content is clipped. */
    overflow-x: auto;
    min-inline-size: 0;
    max-inline-size: 100%;
  }

  /* The shiki <pre> already carries its own padding/border via global.css;
     reset the border here since the figure provides the frame. */
  :global(.codeblock__code pre.shiki) {
    margin: 0;
    border: 0;
    border-radius: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.livepreview__btn),
    :global(.codeblock__copy) {
      transition: none;
    }
  }
</style>
